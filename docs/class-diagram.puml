@startuml BucketAdapter
title BucketAdapter v3 (02.01.26)

class BucketController {
    - bucketService: BucketService

    + BucketController(bucketService: BucketService)
    + upload(string:local, string:remote): void
    + download(string:local, string:remote): void
    + update(string:local, string:remote): void
    + delete(string:remote, bool:recursive): void
    + list(string:remote): string[]
    + share(string:remote, int:expirationTime): string
}

class BucketService {
    - factory: BucketAdapterFactory
    - adapter: BucketAdapter

    + BucketService(factory: BucketAdapterFactory)
    + upload(string:local, string:remote): void
    + download(string:local, string:remote): void
    + update(string:local, string:remote): void
    + delete(string:remote, bool:recursive): void
    + list(string:remote): string[]
    + share(string:remote, int:expirationTime): string
}

class BucketAdapterFactory {
    - adapters: collection<BucketAdapter>

    + getAdapter(): BucketAdapter
}

interface BucketAdapter {
    + upload(string:local, string:remote): void
    + download(string:local, string:remote): void
    + update(string:local, string:remote): void
    + delete(string:remote, bool:recursive): void
    + list(string:remote): string[]
    + doestExists(string:remote): bool
    + share(string:remote, int:expirationTime): string
}

class AzureAdapterImpl
class GcpAdapterImpl

class AwsAdapterImpl {
    - s3Client: S3Client
    - bucket: String
    - s3Presigner: S3Presigner

    + AwsAdapterImpl()
    - AwsAdapterImpl(s3Client: S3Client, bucket: String, s3Presigner: S3Presigner)
    - createS3Client(): S3Client
    - createS3Presigner(): S3Presigner
    - getConfig(envVar: string, configName: string): string
}

' ---- SDK ----
package AWSSDK {
    interface S3Client
    interface S3Presigner
    interface AwsClient
}

package GCPSDK {}
package AZURESDK {}

' ---- Exception ----
package BucketException {
    class BucketOperationException {
        + BucketOperationException(message: String, cause: Exception)
    }

    class BucketObjectNotFoundException {
        + BucketObjectNotFoundException(key: String)
    }

    class InvalidBucketPathException {
        + InvalidBucketPathException(message: String)
    }
}

package Exception {
    class Exception
}

' ---- Relationships ----
BucketController --> BucketService : <<uses>>
BucketService --> BucketAdapterFactory : <<uses>>
BucketAdapterFactory --> BucketAdapter : <<creates>>

BucketAdapter <|.. AwsAdapterImpl
BucketAdapter <|.. GcpAdapterImpl
BucketAdapter <|.. AzureAdapterImpl

BucketException <-- AwsAdapterImpl
BucketException <-- GcpAdapterImpl
BucketException <-- AzureAdapterImpl

BucketException --|> Exception
BucketObjectNotFoundException --|> Exception
InvalidBucketPathException --|> Exception

' Dependency Injection instead of instantiation
AwsAdapterImpl --> S3Client : <<uses>>
AwsAdapterImpl --> S3Presigner : <<uses>>
S3Client ..|> AwsClient

AwsAdapterImpl ..> AWSSDK
GcpAdapterImpl ..> GCPSDK
AzureAdapterImpl ..> AZURESDK

' ---- Test ----
class AwsAdapterImplTest <<test>> {
    - s3Client: S3Client <<mock>>
    - s3Presigner: S3Presigner <<mock>>
    - awsAdapter: AwsAdapterImpl
}

AwsAdapterImplTest --> AwsAdapterImpl : <<injects>>
AwsAdapterImplTest --> S3Client : <<creates mock>>
AwsAdapterImplTest --> S3Presigner : <<creates mock>>

@enduml